# Copy to .env and fill in. .env must be gitignored.

# --- PostgreSQL ---
POSTGRES_DB=openbrain
POSTGRES_USER=openbrain
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# --- MCP Server ---
MCP_PORT=8000
MCP_ACCESS_KEY=change-me-long-random-token

# --- Embedding / Chat API (OpenAI-compatible) ---
# OpenRouter, OpenAI, or a local model server all work.
EMBEDDING_API_BASE=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=openai/text-embedding-3-small
CHAT_API_BASE=https://openrouter.ai/api/v1
CHAT_API_KEY=
CHAT_MODEL=openai/gpt-4o-mini
